{
  "ray5_host": "192.168.1.50",
  "ray5_port": 8848,
  "listen_host": "127.0.0.1",
  "listen_port": 9000,
  "protocol_type": "http",
  "connect_timeout_seconds": 3.0,
  "read_timeout_seconds": 1.0,
  "log_file": "bridge.log",
  "log_dir": "logs",
  "log_retention_days": 7,
  "newline": "\n",
  "status_poll_interval_seconds": 0.0,
  "tcp": {
    "recv_chunk_size": 4096
  },
  "websocket": {
    "url": ""
  },
  "pump_control": {
    "enabled": true,
    "passthrough_m8_m9": true,
    "inject_on_upload_start": false,
    "inject_off_upload_end": false
  },
  "camera": {
    "enabled": true,
    "url": "rtsp://USERNAME:PASSWORD@CAMERA_IP:554/stream2",
    "snapshot_url": "",
    "capture_method": "ffmpeg",
    "output_dir": "camera_captures",
    "filename_prefix": "ray5_bed",
    "keep_last": 25,
    "auto_capture_on_upload": true,
    "auto_capture_on_start": true,
    "open_capture_folder_on_start": false,
    "timeout_seconds": 15,
    "deskew": {
      "enabled": true,
      "source_points": [
        [500, 300],
        [820, 300],
        [860, 560],
        [460, 560]
      ],
      "output_size": [1200, 1200]
    },
    "postprocess": {
      "enabled": true,
      "scale": 1.0,
      "center_crop_margin": 0,
      "rotate_degrees": 90,
      "final_size": [1700, 1700],
      "dpi": 143.93,
      "overlay_guides": {
        "enabled": true,
        "draw_center_cross": true,
        "draw_border": true,
        "draw_corner_marks": true
      }
    }
  },
  "http": {
    "url": "http://192.168.1.50:8848/command",
    "method": "GET",
    "synthetic_grbl_handshake": true,
    "startup_banner": "Grbl 1.1f ['$' for help]",
    "synthetic_grbl_version_line": "[VER:1.1f.20211103:grbl-embedded]",
    "synthetic_grbl_options_line": "[OPT:PHSW,64,256]",
    "content_type": "",
    "headers": {},
    "body_mode": "query_param",
    "body_template": "{command}",
    "command_field": "commandText",
    "response_field": "",
    "debug_protocol": false,
    "synthetic_limits": {
      "x": 390.0,
      "y": 360.0,
      "z": 300.0
    },
    "append_newline_to_body": false,
    "synthetic_status_response": "<Idle|MPos:0.000,0.000,0.000|WPos:0.000,0.000,0.000|WCO:0.000,0.000,0.000|FS:0,0>",
    "spool": {
      "enabled": true,
      "auto_capture_live_jobs": true,
      "start_after_upload": false,
      "idle_seconds": 1.5,
      "job_detect_window_seconds": 2.0,
      "live_frame_passthrough": true,
      "frame_live_passthrough": true,
      "frame_idle_seconds": 0.35,
      "zero_power_frame_passthrough": true,
      "synthetic_motion_status_seconds": 2.0,
      "minimum_job_lines": 10,
      "gzip_level": 6,
      "filename_prefix": "lightburn_job",
      "upload_url": "http://192.168.1.50:8848/upload",
      "upload_path": "/",
      "files_url": "http://192.168.1.50:8848/files",
      "upload_timeout_seconds": 30.0,
      "run_command_template": "$sd/runzip=/{filename}",
      "multipart_filename_mode": "bare",
      "upload_format": "gc",
      "plain_extension": ".gc",
      "screen_compatible_rewrite": true,
      "convert_m4_to_m3": false,
      "gzip_os_byte": 3,
      "upload_query_path": true,
      "filename_mode": "short_counter"
    },
    "dual_mode": {
      "upload_minimum_job_lines": 10,
      "force_frame_live": true,
      "mode_idle_reset_seconds": 0.75
    }
  }
}
